<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Local network için cleartext trafiğine izin ver -->
    <!-- IP adresleri için base-config kullanılır -->
    <!-- Local network (192.168.x.x, 10.x.x.x, 172.16-31.x.x) ve localhost için cleartext izni -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- Production domain'ler için HTTPS zorunlu (isteğe bağlı) -->
    <!-- <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">signaling.videocall.com</domain>
    </domain-config> -->
</network-security-config>

